{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "copilot-api",
  "main": "src/cloudflare.ts",
  "compatibility_date": "2026-04-16",
  "compatibility_flags": ["nodejs_compat"],
  "workers_dev": true,
  "observability": {
    "enabled": true
  },
  "vars": {
    "ACCOUNT_TYPE": "individual",
    "DISABLE_TOKEN_ENDPOINT": "true",
    "SHOW_TOKEN": "false"
  },
  "containers": [
    {
      "class_name": "CopilotApiContainer",
      "image": "./Dockerfile",
      "max_instances": 1,
      "instance_type": "basic"
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "CopilotApiContainer",
        "name": "COPILOT_API"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": [
        "CopilotApiContainer"
      ],
      "tag": "v1"
    }
  ]
}
